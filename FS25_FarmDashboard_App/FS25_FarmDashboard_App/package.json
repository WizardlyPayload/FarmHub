{
  "name": "fs25-farm-dashboard",
  "version": "3.9.0",
  "description": "Real-time Farm Management Dashboard for FS25",
  "author": "JoshWalki / Wizardlypayload & WizardlyPayload",
  "main": "main.js",
  "scripts": {
    "test": "jest",
    "parity": "node ../../tools/app/parity.js",
    "export-fields-csv": "node ../../tools/app/export-fields-to-csv.mjs",
    "unlock-install": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File ../../tools/app/stop-farmdash-install-lock.ps1",
    "unlock-install:delete": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File ../../tools/app/stop-farmdash-install-lock.ps1 -DeleteInstallFolder",
    "clean:build-out": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File ../../tools/app/remove-build-output-folders.ps1",
    "clean:build-out:search": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File ../../tools/app/remove-build-output-folders.ps1 -StopWindowsSearch",
    "start": "electron .",
    "pack": "node ../../tools/app/run-electron-builder.mjs pack",
    "pack:in-repo": "electron-builder --dir",
    "pack:fresh": "node ../../tools/app/electron-builder-fresh-output.mjs pack",
    "pack:alt": "electron-builder --dir --config.directories.output=../electron-pack-out-alt",
    "dist": "node ../../tools/app/run-electron-builder.mjs dist",
    "dist:in-repo": "electron-builder --win",
    "dist:fresh": "node ../../tools/app/electron-builder-fresh-output.mjs dist",
    "dist:alt": "electron-builder --win --config.directories.output=../electron-pack-out-alt",
    "i18n:audit": "node web/locales/audit-keys.mjs",
    "i18n:scan": "node web/locales/find-hardcoded-strings.mjs",
    "i18n:build": "node web/locales/build-translations.mjs",
    "i18n:fill": "node web/locales/mt-fill.mjs",
    "i18n:fill:force": "node web/locales/mt-fill.mjs --force",
    "i18n:verify": "node web/locales/verify-i18n.mjs",
    "i18n:sync": "node web/locales/sync-keys-from-en.mjs"
  },
  "build": {
    "appId": "com.farmdashboard.app",
    "productName": "FS25 Farm Dashboard",
    "directories": {
      "output": "../electron-pack-out"
    },
    "files": [
      "main.js",
      "lanCredentialPolicy.js",
      "app-updater.js",
      "preload.js",
      "xmlCollector.js",
      "fs25Paths.js",
      "fileReadRetry.js",
      "dataMerger.js",
      "serverDataCache.js",
      "setup.html",
      "web/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "../../tools/Export-ModStoreImages.ps1",
        "to": "tools/Export-ModStoreImages.ps1"
      },
      {
        "from": "build/install-imagemagick.ps1",
        "to": "install-imagemagick.ps1"
      },
      {
        "from": "resources/imagemagick",
        "to": "imagemagick",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/texconv",
        "to": "texconv",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Farm Dashboard",
      "warningsAsErrors": false,
      "include": "build/installer.nsh"
    },
    "publish": {
      "provider": "github",
      "owner": "WizardlyPayload",
      "repo": "FarmHub",
      "releaseType": "release"
    }
  },
  "dependencies": {
    "fast-xml-parser": "^5.7.3",
    "basic-ftp": "^5.0.5",
    "cors": "^2.8.5",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.6.2",
    "express": "^4.19.2",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3",
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "<rootDir>/tests/**/*.test.js"
    ]
  }
}
