<!--
    Bridge animals for Witcombe map (FS25_Witcombe).

    This file serves three purposes:
    1. NEW SUBTYPES: Adds male subtypes (BULL_JERSEY, BOAR_GLOUCESTERSHIRE_OLD_SPOT,
       RAM_TEXEL, RAM_SUFFOLK, RAM_BLUE_FACED_LEICESTER, RABBIT_MALE) for full RLRM
       reproduction.
    2. PROPERTY OVERRIDES: Patches breed, weights, pregnancy on existing types/subtypes
       from earlier layers (base game, RLRM, map).
    3. VISUAL OVERRIDES: Fixes visual model indices for COW_HEREFORD and COW_HIGHLAND_CATTLE
       where Witcombe uses custom models at different indices than RLRM's base config.

    Property override rules:
    - Only explicitly defined properties are overridden (omitted = keep current value)
    - Works for both type-level (pregnancy) and subtype-level (weights, reproduction) properties
    - Same XML structure as animals.xml - no special tags needed
-->
<animals>

    <!-- Breed display names for GUI -->
    <breeds>
        <breed name="JERSEY" displayName="$l10n_breed_jersey"/>
        <breed name="GLOUCESTERSHIRE_OLD_SPOT" displayName="$l10n_breed_gloucestershire_old_spot"/>
        <breed name="TEXEL" displayName="$l10n_breed_texel"/>
        <breed name="SUFFOLK" displayName="$l10n_breed_suffolk"/>
        <breed name="BLUE_FACED_LEICESTER" displayName="$l10n_breed_blue_faced_leicester"/>
        <breed name="RABBIT" displayName="$l10n_breed_rabbit"/>
    </breeds>

    <!-- ======================================================================
         COW: Visual + simulation overrides for Hereford and Highland Cattle.

         Hereford: full property override (heritage signatures applied on top of
           the RLRM-bundle universal modernisation; see the per-block comment
           on COW_HEREFORD below for the rationale and math). RLRM uses Limousin
           models (indices 16/17/18) for Hereford because the base game has no
           dedicated Hereford models. Witcombe adds custom Hereford models at
           indices 8/12/4.

         Highland Cattle: visual-only override (indices shifted RLRM 19/20/21 ->
           Witcombe 16/17/18). NO simulation override is added by design - the
           map's animals.xml registers COW_HIGHLAND_CATTLE later than the RLRM
           bundle, so the engine's first-registration-wins rule keeps the
           bundle's modernised stats live and the map's BASE-Angus-vintage
           values are dead code at runtime. Adding any reproduction / price /
           input / output block here would either restate live values (dead
           bytes) or regress the bundle's modernisation. The bull mirrors the
           cow: visual-only by the same load-order argument.
         ====================================================================== -->
    <animal type="COW">
        <!-- COW_HEREFORD: leaner heritage beef breed with shorter gestation, premium
             pricing, and a young-beef sell-curve. RLRM Phase 1 wins on the duplicate
             subtype name, so map-author character must be re-applied via this override
             to be reachable in-game.

             Override applies these adjustments (each preserves the breed signature):
               reproduction.durationMonth=9 (heritage shorter gestation). Single-attr
                 override leaves minAgeMonth=12 + minHealthFactor=0.75 intact (universal
                 cattle maturity gate kept).
               buyPrice 300/3000 (heritage premium calf + adult).
               sellPrice 5-key 250/2500/3500/2600/1500 at 0/18/24/36/60m: extra 18m
                 keyframe at 2500 models the young-beef premium market signature.
               straw 15/100, manure 25/200, liquidManure 40/180 (leaner adult outputs).
               water 40/100 at 0m/18m: calf 40 derived as 0.667 x donor calf-realism
                 value 60, where 0.667 = breed adult 100 / donor adult 150. Adult 100
                 preserves the leaner-adult signature.
               food 80/280/380 at 0m/12m/18m: calf 80 preserved (signal-bearing value
                 distinct from the RLRM-bundle's anomalously lower calf=65 for this
                 breed). 12m midpoint 280 matches the donor curve since the breed
                 adult/donor adult ratio = 1.0. Adult 380 agreed by both sources.

             RL universal modernisation kept (NOT overridden in this block):
               reproduction.minAgeMonth=12 (universal cattle maturity gate)
               transportPrice 40/100/200 (universal RLRM cattle modernisation)
               milk 0/0/190/190/265/265/125 dual-purpose curve (intentional uniform
                 RLRM design for beef breeds; not removed)

             BULL_HEREFORD untouched (no map-author character defined for the bull). -->
        <subType subType="COW_HEREFORD">
            <visuals>
                <visual minAge="0" visualAnimalIndex="8" image="map/config/cows/store_cowHerefordBaby.png"/>
                <visual minAge="6" visualAnimalIndex="12" image="map/config/cows/store_cowHerefordKid.png"/>
                <visual minAge="12" visualAnimalIndex="4" image="map/config/cows/store_cowHereford.png"/>
                <visual minAge="18" visualAnimalIndex="4" image="map/config/cows/store_cowHereford.png"/>
            </visuals>
            <reproduction durationMonth="9"/>
            <buyPrice>
                <key ageMonth="0" value="300"/>
                <key ageMonth="24" value="3000"/>
            </buyPrice>
            <sellPrice>
                <key ageMonth="0" value="250"/>
                <key ageMonth="18" value="2500"/>
                <key ageMonth="24" value="3500"/>
                <key ageMonth="36" value="2600"/>
                <key ageMonth="60" value="1500"/>
            </sellPrice>
            <input>
                <straw>
                    <key ageMonth="0" value="15"/>
                    <key ageMonth="18" value="100"/>
                </straw>
                <water>
                    <key ageMonth="0" value="40"/>
                    <key ageMonth="18" value="100"/>
                </water>
                <food>
                    <key ageMonth="0" value="80"/>
                    <key ageMonth="12" value="280"/>
                    <key ageMonth="18" value="380"/>
                </food>
            </input>
            <output>
                <manure>
                    <key ageMonth="0" value="25"/>
                    <key ageMonth="18" value="200"/>
                </manure>
                <liquidManure>
                    <key ageMonth="0" value="40"/>
                    <key ageMonth="18" value="180"/>
                </liquidManure>
            </output>
        </subType>

        <!-- BULL_HEREFORD: leaner heritage beef Hereford bull. The cow side carries
             the heritage shorter-gestation trait (durationMonth=9) which doesn't
             apply to the male; the bull contributes only the breeding-age gate
             (minAgeMonth=12) to the pair.

             Curve values:
               reproduction supported=false, minAgeMonth=12
               buyPrice 375/3375: heritage-premium pricing for breeding-stock bull
               sellPrice 5-key 365/3000/4200/3035/1930 at 0/18/24/36/60m:
                 young-beef shape with 18m premium and a 36m peak typical for
                 heritage beef bulls
               transportPrice 40/150/500: heavy-livestock transport rates
               straw 15/100: leaner adult bedding consistent with the leaner-frame
                 heritage signature
               water 40/100: leaner adult demand. Calf 40 reflects calf-stage demand
                 scaled to the breed's leaner frame
               food 80/290/390: leaner-but-bigger-bull-side adult; 12m midpoint 290
                 follows the growth-spurt curve shape with a small bull-side bump
               manure 25/185 / liquidManure 40/160: leaner waste outputs consistent
                 with the leaner-frame signature; small bull-side reductions vs
                 cow-equivalent values
               (no milk produced - bulls do not lactate) -->
        <subType subType="BULL_HEREFORD">
            <visuals>
                <visual minAge="0" visualAnimalIndex="8" image="map/config/cows/store_cowHerefordBaby.png"/>
                <visual minAge="6" visualAnimalIndex="12" image="map/config/cows/store_cowHerefordKid.png"/>
                <visual minAge="12" visualAnimalIndex="4" image="map/config/cows/store_cowHereford.png"/>
                <visual minAge="18" visualAnimalIndex="4" image="map/config/cows/store_cowHereford.png"/>
            </visuals>
            <reproduction supported="false" minAgeMonth="12"/>
            <buyPrice>
                <key ageMonth="0" value="375"/>
                <key ageMonth="24" value="3375"/>
            </buyPrice>
            <sellPrice>
                <key ageMonth="0" value="365"/>
                <key ageMonth="18" value="3000"/>
                <key ageMonth="24" value="4200"/>
                <key ageMonth="36" value="3035"/>
                <key ageMonth="60" value="1930"/>
            </sellPrice>
            <transportPrice>
                <key ageMonth="0" value="40"/>
                <key ageMonth="12" value="150"/>
                <key ageMonth="18" value="500"/>
            </transportPrice>
            <input>
                <straw>
                    <key ageMonth="0" value="15"/>
                    <key ageMonth="18" value="100"/>
                </straw>
                <water>
                    <key ageMonth="0" value="40"/>
                    <key ageMonth="18" value="100"/>
                </water>
                <food>
                    <key ageMonth="0" value="80"/>
                    <key ageMonth="12" value="290"/>
                    <key ageMonth="18" value="390"/>
                </food>
            </input>
            <output>
                <manure>
                    <key ageMonth="0" value="25"/>
                    <key ageMonth="18" value="185"/>
                </manure>
                <liquidManure>
                    <key ageMonth="0" value="40"/>
                    <key ageMonth="18" value="160"/>
                </liquidManure>
            </output>
        </subType>

        <!-- COW_HIGHLAND_CATTLE: visual indices 19/20/21/21 -> 16/17/18/18 -->
        <subType subType="COW_HIGHLAND_CATTLE">
            <visuals>
                <visual minAge="0" visualAnimalIndex="16"/>
                <visual minAge="6" visualAnimalIndex="17"/>
                <visual minAge="12" visualAnimalIndex="18"/>
                <visual minAge="18" visualAnimalIndex="18"/>
            </visuals>
        </subType>

        <!-- BULL_HIGHLAND_CATTLE: same index fix as COW_HIGHLAND_CATTLE -->
        <subType subType="BULL_HIGHLAND_CATTLE">
            <visuals>
                <visual minAge="0" visualAnimalIndex="16"/>
                <visual minAge="6" visualAnimalIndex="17"/>
                <visual minAge="12" visualAnimalIndex="18"/>
                <visual minAge="18" visualAnimalIndex="18"/>
            </visuals>
        </subType>

        <!-- COW_JERSEY: small-frame, drought-efficient heritage dairy. Override applies
             these adjustments (each value chosen to preserve breed signature endpoints):
               reproduction.minAgeMonth 12: matches universal cattle maturity gate.
                 Single-attribute override leaves durationMonth=9 + minHealthFactor=0.75
                 intact (heritage shorter gestation preserved).
               transportPrice 40/100/200 at 0m/12m/18m: full curve replace; no
                 transport signature on this breed.
               water 32/75 at 0m/18m: calf 32 derived as 0.577 x donor calf-realism
                 value 55, where 0.577 = breed adult 75 / donor adult 130. Adult 75
                 preserves the drought-efficiency signature.
               food 80/223/280 at 0m/12m/18m: 12m midpoint 223 derived as 0.797 x
                 breed adult 280, where 0.797 is the donor's growth-spurt ratio.
                 Endpoints 0m=80 + 18m=280 preserve the small-frame signature.
               milk 0/0/113/113/160/160/69 at 0m/12m/12m/36m/36m/72m/120m: full
                 three-stage lactation shape (floor / peak / senescence) scaled to
                 peak 160. Floor 113 = 0.706 x 160; senescence 69 = 0.431 x 160.
                 Peak 160 preserves the small-frame dairy signature.

             Witcombe-source signatures preserved (NOT overridden in this block):
               reproduction.durationMonth=9 (heritage shorter gestation)
               buyPrice 300/2500 (heritage premium)
               sellPrice 250/2000/2800/2200/1200 (young-market peak + fast-aging)
               straw 15/75 (lower bedding need)
               manure 25/150, liquidManure 40/130 -->
        <subType subType="COW_JERSEY" breed="JERSEY">
            <reproduction minAgeMonth="12"/>
            <transportPrice>
                <key ageMonth="0" value="40"/>
                <key ageMonth="12" value="100"/>
                <key ageMonth="18" value="200"/>
            </transportPrice>
            <input>
                <water>
                    <key ageMonth="0" value="32"/>
                    <key ageMonth="18" value="75"/>
                </water>
                <food>
                    <key ageMonth="0" value="80"/>
                    <key ageMonth="12" value="223"/>
                    <key ageMonth="18" value="280"/>
                </food>
            </input>
            <output>
                <milk fillType="MILK">
                    <key ageMonth="0" value="0"/>
                    <key ageMonth="12" value="0"/>
                    <key ageMonth="12" value="113"/>
                    <key ageMonth="36" value="113"/>
                    <key ageMonth="36" value="160"/>
                    <key ageMonth="72" value="160"/>
                    <key ageMonth="120" value="69"/>
                </milk>
            </output>
        </subType>

        <!-- BULL_JERSEY: small-frame, drought-efficient heritage dairy bull.

             Curve values:
               reproduction supported=false, minAgeMonth=12 (breeding-age gate)
               buyPrice 375/2800: heritage-premium pricing for breeding-stock bull
               sellPrice 5-key 365/2400/3360/2570/1540 at 0/18/24/36/60m:
                 young-market shape with 18m early-sale premium
               transportPrice 40/150/500: heavy-livestock transport rates
               straw 15/75: low bedding need
               water 32/75: drought-efficient adult. Calf 32 = (75/130) x 55,
                 scaling species-typical calf-stage demand to the breed's
                 small-frame adult signature
               food 80/230/290: small-frame adult; 12m midpoint 230 follows the
                 growth-spurt curve shape with a small bull-side bump per keyframe
               manure 25/140 / liquidManure 40/120: leaner waste outputs consistent
                 with the small-frame signature; small bull-side reductions on
                 the adult keyframe
               (no milk produced - bulls do not lactate) -->
        <subType subType="BULL_JERSEY" fillTypeName="BULL_JERSEY"
                 gender="male" breed="JERSEY"
                 minWeight="35.0" targetWeight="700.0" maxWeight="1200.0">
            <visuals>
                <visual minAge="0" visualAnimalIndex="5" name="$l10n_animal_visual_baby"
                        image="$dataS/character/animals/domesticated/cow/store_cowSwissBrownBaby.png"
                        canBeBought="true">
                    <description>$l10n_rl_bridge_bullJerseyCalfDesc</description>
                </visual>
                <visual minAge="6" visualAnimalIndex="9" name="$l10n_animal_visual_kid"
                        image="$dataS/character/animals/domesticated/cow/store_cowSwissBrownKid.png"
                        canBeBought="true">
                    <description>$l10n_rl_bridge_bullJerseyYoungDesc</description>
                </visual>
                <visual minAge="12" visualAnimalIndex="1" name="$l10n_animal_visual_adult"
                        image="$dataS/character/animals/domesticated/cow/store_cowSwissBrown.png"
                        canBeBought="false">
                    <description>$l10n_rl_bridge_bullJerseyAdultDesc</description>
                </visual>
                <visual minAge="18" visualAnimalIndex="1" name="$l10n_animal_visual_adult"
                        image="$dataS/character/animals/domesticated/cow/store_cowSwissBrown.png"
                        canBeBought="true">
                    <description>$l10n_rl_bridge_bullJerseyAdultDesc</description>
                </visual>
            </visuals>
            <reproduction supported="false" minAgeMonth="12"/>
            <buyPrice>
                <key ageMonth="0" value="375"/>
                <key ageMonth="24" value="2800"/>
            </buyPrice>
            <sellPrice>
                <key ageMonth="0" value="365"/>
                <key ageMonth="18" value="2400"/>
                <key ageMonth="24" value="3360"/>
                <key ageMonth="36" value="2570"/>
                <key ageMonth="60" value="1540"/>
            </sellPrice>
            <transportPrice>
                <key ageMonth="0" value="40"/>
                <key ageMonth="12" value="150"/>
                <key ageMonth="18" value="500"/>
            </transportPrice>
            <input>
                <straw>
                    <key ageMonth="0" value="15"/>
                    <key ageMonth="18" value="75"/>
                </straw>
                <water>
                    <key ageMonth="0" value="32"/>
                    <key ageMonth="18" value="75"/>
                </water>
                <food>
                    <key ageMonth="0" value="80"/>
                    <key ageMonth="12" value="230"/>
                    <key ageMonth="18" value="290"/>
                </food>
            </input>
            <output>
                <manure>
                    <key ageMonth="0" value="25"/>
                    <key ageMonth="18" value="140"/>
                </manure>
                <liquidManure>
                    <key ageMonth="0" value="40"/>
                    <key ageMonth="18" value="120"/>
                </liquidManure>
            </output>
        </subType>
    </animal>

    <!-- ======================================================================
         PIG: New male subtype + breed override
         PIG_GLOUCESTERSHIRE_OLD_SPOT uses Black Pied visual models (indices 4/5/6)
         ====================================================================== -->
    <animal type="PIG">
        <!-- PIG_GLOUCESTERSHIRE_OLD_SPOT: heritage slow-breeder, slow-grow, premium-priced
             pig. Override applies these adjustments (each preserves the breed signature):
               transportPrice 30/50/150 at 0m/6m/12m: 12m endpoint added; 0m/6m
                 preserved as authored. No transport signature on this breed.
               water 3/15 at 0m/8m: calf 3 derived as 0.429 x donor calf-realism
                 value 8, where 0.429 = breed adult 15 / donor adult 35. Adult 15
                 and stop-at-8m end-age preserved (slow-grow signature).
               food 10/40/65 at 0m/6m/10m: calf 10 derived as 0.65 x donor calf-realism
                 value 15, where 0.65 = breed adult 65 / donor adult 100. 6m midpoint 40
                 and 10m custom keyframe 65 preserved (deliberate slow-grow ramp signature
                 distinct from the donor's 2-keyframe shape).
               manure 13/40 at 0m/8m: calf 13 derived as 0.889 x donor calf 15.
                 Adult 40 and stop-at-8m end-age preserved.
               liquidManure 25/60 at 0m/8m: calf 25 derived as 0.706 x donor calf 35.
                 Adult 60 and stop-at-8m end-age preserved. (Calf 25 is slightly lower
                 than the source-XML value 30 because the breed-frame ratio 60/85
                 applied to the donor's elevated calf 35 yields a smaller value;
                 consistent with the small-frame-scaling principle used elsewhere.)

             Witcombe-source signatures preserved (NOT overridden in this block):
               reproduction minAgeMonth=8 (heritage slow-breeder; already live)
               reproduction durationMonth=4, minHealthFactor=0.75
               buyPrice 250/1500 (heritage premium calf + base-vintage adult ceiling)
               sellPrice 125/2500 (heritage premium calf + base-vintage adult)
               straw 5/25 at 0m/8m (slow-grow extension + higher end-value signatures) -->
        <subType subType="PIG_GLOUCESTERSHIRE_OLD_SPOT" breed="GLOUCESTERSHIRE_OLD_SPOT">
            <transportPrice>
                <key ageMonth="0" value="30"/>
                <key ageMonth="6" value="50"/>
                <key ageMonth="12" value="150"/>
            </transportPrice>
            <input>
                <water>
                    <key ageMonth="0" value="3"/>
                    <key ageMonth="8" value="15"/>
                </water>
                <food>
                    <key ageMonth="0" value="10"/>
                    <key ageMonth="6" value="40"/>
                    <key ageMonth="10" value="65"/>
                </food>
            </input>
            <output>
                <manure>
                    <key ageMonth="0" value="13"/>
                    <key ageMonth="8" value="40"/>
                </manure>
                <liquidManure>
                    <key ageMonth="0" value="25"/>
                    <key ageMonth="8" value="60"/>
                </liquidManure>
            </output>
        </subType>

        <!-- BOAR_GLOUCESTERSHIRE_OLD_SPOT: heritage slow-breeder, slow-grow,
             premium-priced GOS boar.

             Curve values:
               reproduction supported=false, minAgeMonth=8 (heritage slow-breeder
                 gate matches the sow's)
               buyPrice 295/1900: heritage-premium pricing for breeding-stock boar
               sellPrice 155/2950 at 0m/24m: heritage-premium 2-key sell shape
                 (no 6m midpoint - matches the sow's authored 2-key structure)
               transportPrice 40/125/250 at 0m/6m/12m: heavy-livestock transport
                 rates applied across the whole curve (the sow side preserved
                 lower BASE-vintage rates at 0m/6m for breed-character reasons;
                 the bull side uses the modernised rates for all three keyframes
                 since transport is shape-agnostic)
               straw 5/25 at 0m/8m: slow-grow age extension preserved on the male
                 side; same 8m end-age as the sow
               water 3/15 at 0m/8m: heritage-frame demand. Calf 3 reflects
                 calf-stage demand scaled to the breed's small-frame ratio
               food 10/40/72 at 0m/6m/10m: slow-grow custom 3-key shape preserved;
                 calf 10 + 6m midpoint 40 mirror the sow exactly; 10m extension
                 72 applies a small bull-side bump on the end keyframe
               manure 13/43 at 0m/8m: slow-grow end-age preserved; calf 13 mirrors
                 sow; 8m adult 43 applies a small bull-side bump
               liquidManure 25/64 at 0m/8m: same structure - calf mirrors sow,
                 adult 64 applies a small bull-side bump
               (no milk produced - this species does not lactate in any source) -->
        <subType subType="BOAR_GLOUCESTERSHIRE_OLD_SPOT" fillTypeName="BOAR_GLOUCESTERSHIRE_OLD_SPOT"
                 gender="male" breed="GLOUCESTERSHIRE_OLD_SPOT"
                 minWeight="1.75" targetWeight="250.0" maxWeight="1200.0">
            <visuals>
                <visual minAge="0" visualAnimalIndex="4" name="$l10n_animal_visual_baby"
                        image="$dataS/character/animals/domesticated/pig/store_pigBlackPiedBaby.png"
                        canBeBought="true">
                    <description>$l10n_rl_bridge_boarGOSPigletDesc</description>
                </visual>
                <visual minAge="3" visualAnimalIndex="5" name="$l10n_animal_visual_kid"
                        image="$dataS/character/animals/domesticated/pig/store_pigBlackPiedKid.png"
                        canBeBought="true">
                    <description>$l10n_rl_bridge_boarGOSYoungDesc</description>
                </visual>
                <visual minAge="6" visualAnimalIndex="6" name="$l10n_animal_visual_adult"
                        image="$dataS/character/animals/domesticated/pig/store_pigBlackPied.png"
                        canBeBought="true">
                    <description>$l10n_rl_bridge_boarGOSAdultDesc</description>
                </visual>
            </visuals>
            <reproduction supported="false" minAgeMonth="8"/>
            <buyPrice>
                <key ageMonth="0" value="295"/>
                <key ageMonth="12" value="1900"/>
            </buyPrice>
            <sellPrice>
                <key ageMonth="0" value="155"/>
                <key ageMonth="24" value="2950"/>
            </sellPrice>
            <transportPrice>
                <key ageMonth="0" value="40"/>
                <key ageMonth="6" value="125"/>
                <key ageMonth="12" value="250"/>
            </transportPrice>
            <input>
                <straw>
                    <key ageMonth="0" value="5"/>
                    <key ageMonth="8" value="25"/>
                </straw>
                <water>
                    <key ageMonth="0" value="3"/>
                    <key ageMonth="8" value="15"/>
                </water>
                <food>
                    <key ageMonth="0" value="10"/>
                    <key ageMonth="6" value="40"/>
                    <key ageMonth="10" value="72"/>
                </food>
            </input>
            <output>
                <manure>
                    <key ageMonth="0" value="13"/>
                    <key ageMonth="8" value="43"/>
                </manure>
                <liquidManure>
                    <key ageMonth="0" value="25"/>
                    <key ageMonth="8" value="64"/>
                </liquidManure>
            </output>
        </subType>
    </animal>

    <!-- ======================================================================
         SHEEP: New male subtypes + breed overrides for map-specific breeds
         Texel uses Steinschaf models (4/5/6), Suffolk and BFL use Landrace models (1/2/3)
         ====================================================================== -->
    <animal type="SHEEP">
        <!-- SHEEP_TEXEL: heavier-frame meat sheep with early-market lamb peak,
             stops-at-8m maturity-aligned input curves, and low wool peak. Override
             adds the universal sheep field-additions scoped to the breed's 8m maturity:
               transportPrice 30/50/150 at 0m/8m/18m: 18m endpoint added; 0m/8m
                 preserved as authored.
               straw added: 3/20 at 0m/8m. End-age 8m matches the breed's other input
                 curves; do not extend to 18m senescence (would break stop-at-8m
                 consistency).
               manure added: 5/16 at 0m/8m. Same end-age scoping as straw.

             Witcombe-source signatures preserved (NOT overridden in this block):
               reproduction 8/5/0.75
               buyPrice 250/1800 (heritage premium)
               sellPrice 120/600/1200 at 0m/8m/8m (early-market lamb 5-key shape:
                 step-jump from 600 to 1200 at 8m maturity)
               water 5/30 at 0m/8m (heavier-frame adult; calf already above the
                 universal calf-realism baseline, no scaled raise needed)
               food 10/75 at 0m/8m (same reasoning as water)
               wool 0/0/10/25 at 0m/6m/6m/18m (4-key shape preserves lamb-shearing-
                 onset realism: production stays at zero before 6m. Peak 25 is the
                 meat-breed-low-wool signature.) -->
        <subType subType="SHEEP_TEXEL" breed="TEXEL">
            <transportPrice>
                <key ageMonth="0" value="30"/>
                <key ageMonth="8" value="50"/>
                <key ageMonth="18" value="150"/>
            </transportPrice>
            <input>
                <straw>
                    <key ageMonth="0" value="3"/>
                    <key ageMonth="8" value="20"/>
                </straw>
            </input>
            <output>
                <manure>
                    <key ageMonth="0" value="5"/>
                    <key ageMonth="8" value="16"/>
                </manure>
            </output>
        </subType>

        <!-- SHEEP_SUFFOLK: fast-breeder (minAgeMonth=6) medium-frame meat sheep with
             early-market lamb peak. Override adds the universal sheep field-additions
             scoped to the breed's 6m maturity:
               transportPrice 30/50/150 at 0m/8m/18m: 18m endpoint added; 0m/8m
                 preserved as authored.
               straw added: 3/20 at 0m/6m. End-age 6m matches the breed's other input
                 curves (do not extend to 18m senescence).
               manure added: 5/16 at 0m/6m. Same end-age scoping as straw.

