<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUI onOpen="onOpen" onClose="onClose" onCreate="onCreate">
	<GuiElement profile="newLayer"/>
	<Bitmap profile="dialogFullscreenBg" id="dialogBg"/>
	<GuiElement profile="fs25_dialogBg" id="dialogElement" size="600px 740px">
		<ThreePartBitmap profile="fs25_dialogBgMiddle"/>
		<ThreePartBitmap profile="fs25_dialogBgTop"/>
		<ThreePartBitmap profile="fs25_dialogBgBottom"/>
		<GuiElement profile="fs25_dialogContentContainer">
			<Text profile="dialogTitle" text="$l10n_rl_ui_moveSelectDestination" id="dialogTitleElement" position="0px -30px"/>

			<!-- Empty state message -->
			<Text profile="fs25_dialogText" text="$l10n_rl_ui_moveNoDestinations" id="emptyListText" position="0px -200px" size="500px 40px" visible="false"/>

			<!-- Destination list -->
			<SmoothList profile="rl_moveDestList" id="destinationList" position="50px -80px" size="470px 550px" focusInit="onOpen" focusChangeTop="nil" focusChangeBottom="nil" onClick="onListClick">
				<ListItem profile="rl_moveDestListItem" size="455px 55px">
					<Text profile="rl_moveDestName" position="10px -5px" size="310px 28px" name="destinationName"/>
					<Text profile="rl_moveDestConstraint" position="10px -30px" size="310px 22px" name="constraintText"/>
					<Text profile="rl_moveDestCapacity" position="330px 0px" size="120px 55px" name="capacityText"/>
				</ListItem>
			</SmoothList>

			<!-- Scrollbar -->
			<ThreePartBitmap profile="fs25_listSliderBox" position="-30px -17px" size="12px 550px" with="anchorTopRight">
				<Slider profile="fs25_listSlider" size="6px 542px" dataElementId="destinationList"/>
			</ThreePartBitmap>
		</GuiElement>

		<BoxLayout profile="fs25_dialogButtonBox" id="buttonsPC">
			<Button profile="buttonOK" text="$l10n_button_confirm" onClick="onClickConfirm" id="confirmButton"/>
			<Bitmap profile="fs25_dialogButtonBoxSeparator"/>
			<Button profile="buttonBack" text="$l10n_button_back" onClick="onClickCancel"/>
		</BoxLayout>
	</GuiElement>

	<GUIProfiles>
		<Profile name="rl_moveDestList" extends="emptyPanel" with="anchorStretchingYLeft pivotTopLeft">
		</Profile>
		<Profile name="rl_moveDestListItem" extends="baseReference" with="anchorTopStretchingX alternating">
			<height value="55px"/>
			<imageColor value="$preset_fs25_colorGrey"/>
			<imageSelectedColor value="$preset_fs25_colorMainHighlight"/>
			<alternateBackgroundColor value="$preset_fs25_colorGreyDark_50"/>
		</Profile>
		<Profile name="rl_moveDestName" extends="baseReference" with="anchorTopLeft">
			<textBold value="false"/>
			<textSize value="18px"/>
			<textAlignment value="left"/>
			<textColor value="$preset_fs25_colorMainLight"/>
			<textSelectedColor value="$preset_fs25_colorMainDark"/>
		</Profile>
		<Profile name="rl_moveDestConstraint" extends="baseReference" with="anchorTopLeft">
			<textBold value="false"/>
			<textSize value="13px"/>
			<textAlignment value="left"/>
			<textColor value="$preset_colorWhite_50"/>
			<textSelectedColor value="$preset_fs25_colorMainDark"/>
		</Profile>
		<Profile name="rl_moveDestCapacity" extends="baseReference" with="anchorStretchingYLeft">
			<textBold value="true"/>
			<textSize value="16px"/>
			<textAlignment value="right"/>
			<textColor value="$preset_fs25_colorMainHighlight"/>
			<textSelectedColor value="$preset_fs25_colorMainDark"/>
		</Profile>
	</GUIProfiles>
</GUI>
